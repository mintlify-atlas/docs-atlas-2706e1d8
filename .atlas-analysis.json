    "POST /api/confirm-invite — add a user to a group",
    "POST /api/download-content — download a track",
    "Server Action: uploadFileToSupabase(file)",
    "Server Action: uploadMusic(fileMetadata, title, artist, groupId)",
    "Server Action: getTracksForGroup(groupId)",
    "Server Action: getTracksFromUser(userId)",
    "Server Action: getTracksFromAllGroups(userId)",
